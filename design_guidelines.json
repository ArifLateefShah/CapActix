  "testing": {
    "rules": [
      "All interactive elements MUST have a data-testid attribute.",
      "Use kebab-case and role-based naming (e.g., data-testid='sidebar-nav-clients')."
    ]
  },
  "instructions_to_main_agent": [
    "You are building 20 specific screens. Rely on standard Shadcn UI components but override border radii to match the guidelines (8px cards, 6px inputs).",
    "CRITICAL: Generate `.js` or `.jsx` files only. DO NOT generate `.tsx` or `.ts` files.",
    "Linear meets QuickBooks: The UI must be highly functional, dense, and clean. Strip away unnecessary drop shadows and gradients.",
    "Use Phosphor Icons or Lucide React for consistent line-art iconography.",
    "Data Mocking: Create deep, realistic JSON objects for CPAs (e.g., '1040 Tax Returns', 'Q3 Bookkeeping', 'Audit for Acme Corp').",
    "Gantt Charts: Use Recharts grouped horizontal bar charts or map pure HTML/Tailwind flex blocks to build the Resource Allocation view.",
    "For Client Portal Preview, wrap the view in a 'browser chrome' mock to differentiate it from the admin layout.",
    "Always apply data-testid to everything clickable or significant for testing purposes."
  ]
